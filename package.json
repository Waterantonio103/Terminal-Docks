{
  "name": "terminal-docks",
  "private": true,
  "version": "0.1.0",
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"tsc -p electron/tsconfig.json -w\" \"wait-on tcp:1420 && electron .\"",
    "electron:build": "vite build && tsc -p electron/tsconfig.json && electron-builder",
    "mcp:install": "npm install --prefix mcp-server",
    "tdctl": "node ./scripts/tdctl.mjs",
    "test:graph": "tsc -p tsconfig.graph-tests.json && node ./tests/graphCompiler.test.mjs",
    "test:mcp": "node ./tests/mcpPersistenceOwnership.test.mjs && node ./tests/mcpStableTools.test.mjs && node ./tests/mcpGraphMode.test.mjs",
    "test:smoke": "tsc -p tsconfig.graph-tests.json && node ./tests/missionFlow.smoke.mjs",
    "test:prompt-parity": "node ./tests/promptToolParity.test.mjs",
    "test:headless": "tsc -p tsconfig.graph-tests.json && node ./tests/headlessRuntime.test.mjs",
    "test:runtime-core": "node ./tests/runtimeManagerHeadless.test.mjs",
    "test:providers": "node ./tests/runtimeProviderAdapters.test.mjs",
    "test:control-plane": "node ./tests/controlPlane.test.mjs",
    "test:rust": "cargo test --manifest-path backend/Cargo.toml workflow_engine",
    "test:workflow": "npm run test:graph && npm run test:mcp && npm run test:smoke && npm run test:prompt-parity && npm run test:headless && npm run test:runtime-core && npm run test:providers && npm run test:control-plane && npm run test:rust"
  },
  "dependencies": {
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@tailwindcss/vite": "^4.2.2",
    "@uiw/react-codemirror": "^4.25.9",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "@xyflow/react": "^12.10.2",
    "lucide-react": "^1.8.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "tailwindcss": "^4.2.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "concurrently": "^9.2.1",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.27.7",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "wait-on": "^9.0.5"
  }
}
