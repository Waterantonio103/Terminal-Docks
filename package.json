{
  "name": "comet-ai",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "preflight:live-workflow": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/live-workflow-preflight.ps1",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "mcp:install": "npm install --prefix mcp-server",
    "test:graph": "tsc -p tsconfig.graph-tests.json && node ./tests/graphCompiler.test.mjs && node ./tests/workflowOrchestratorRuntimeRace.test.mjs",
    "test:mcp": "node ./tests/mcpGraphMode.test.mjs",
    "test:smoke": "tsc -p tsconfig.graph-tests.json && node ./tests/missionFlow.smoke.mjs",
    "test:prompt-parity": "node ./tests/promptToolParity.test.mjs",
    "test:runtime-adapters": "tsc -p tsconfig.graph-tests.json && node ./tests/runtimeAdapters.test.mjs",
    "test:headless": "npm run test:runtime-adapters && node ./tests/runtimeReadinessGate.test.mjs && node ./tests/launchProfileHardening.test.mjs && node ./tests/headlessRuntime.test.mjs",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml workflow_engine",
    "test:workflow": "npm run test:graph && npm run test:mcp && npm run test:smoke && npm run test:prompt-parity && npm run test:headless && npm run test:rust"
  },
  "dependencies": {
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@tailwindcss/vite": "^4.2.2",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-fs": "^2.5.0",
    "@tauri-apps/plugin-opener": "^2",
    "@uiw/react-codemirror": "^4.25.9",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "@xyflow/react": "^12.10.2",
    "lucide-react": "^1.8.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "tailwindcss": "^4.2.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
}
